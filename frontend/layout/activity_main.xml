<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/circle_bg"/>

        <LinearLayout
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <TextView
                android:text="Hello 👋"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:text="How are you feeling today?"
                android:textColor="#AAAAAA"
                android:textSize="14sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Gradient Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_marginTop="20dp"
        android:padding="20dp"
        android:background="@drawable/gradient_card"
        android:orientation="vertical">

        <TextView
            android:text="Today's Affirmation ✨"
            android:textColor="#FFFFFF"/>

        <TextView
            android:text="I choose to listen to my body and care for it with kindness today."
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginTop="10dp"/>
    </LinearLayout>

    <!-- Actions -->
    <TextView
        android:text="Your Actions"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginTop="20dp"/>

    <!-- Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginTop="10dp"
        android:padding="16dp"
        android:background="@drawable/gradient_small_card"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:text="Track Symptoms"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Bottom Nav -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="auto"
        android:background="#121212"
        app:menu="@menu/bottom_menu"/>
</LinearLayout>
